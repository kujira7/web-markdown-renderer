{
  "manifest_version": 3,
  "name": "Web Markdown Renderer",
  "version": "0.3.6",
  "description": "Render selected text as readable Markdown without posting or editing anything.",
  "permissions": ["activeTab", "contextMenus", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Read selection as Markdown"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+M",
        "mac": "Command+M"
      },
      "description": "Read selected text as Markdown"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["vendor/marked.umd.js", "vendor/mermaid.min.js", "renderer.js", "content.js"],
      "css": ["viewer.css"],
      "run_at": "document_idle"
    }
  ]
}
